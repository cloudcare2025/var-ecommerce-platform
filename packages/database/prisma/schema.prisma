// =============================================================================
// SYNC INFRASTRUCTURE — Job Tracking
// =============================================================================

model SyncJob {
  id             String    @id @default(cuid())
  jobType        String    @map("job_type") // full_catalog | incremental_pna | webhook_update
  distributor    String?
  status         String    @default("pending") // pending | running | completed | failed
  itemsProcessed Int       @default(0) @map("items_processed")
  itemsCreated   Int       @default(0) @map("items_created")
  itemsUpdated   Int       @default(0) @map("items_updated")
  itemsFailed    Int       @default(0) @map("items_failed")
  errorLog       Json?     @map("error_log")
  startedAt      DateTime  @default(now()) @map("started_at")
  completedAt    DateTime? @map("completed_at")

  @@index([jobType])
  @@index([status])
  @@index([startedAt])
  @@map("sync_jobs")
}

model ProductTier {
  id            String      @id @default(cuid())
  syncProductId String      @unique @map("sync_product_id")
  syncProduct   SyncProduct @relation(fields: [syncProductId], references: [id], onDelete: Cascade)
  tier          String      @default("standard") // hot | standard | cold
  pageViews7d   Int         @default(0) @map("page_views_7d")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@index([tier])
  @@map("product_tiers")
}

model FtpSyncState {
  id             String    @id @default(cuid())
  distributor    String
  feedType       String    @map("feed_type")
  fileName       String?   @map("file_name")
  fileSize       BigInt?   @map("file_size")
  fileModified   DateTime? @map("file_modified")
  lastRunAt      DateTime? @map("last_run_at")
  lastStatus     String    @default("pending") @map("last_status")
  itemsProcessed Int       @default(0) @map("items_processed")
  itemsCreated   Int       @default(0) @map("items_created")
  itemsUpdated   Int       @default(0) @map("items_updated")
  itemsFailed    Int       @default(0) @map("items_failed")
  errorMessage   String?   @map("error_message")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@unique([distributor, feedType])
  @@map("ftp_sync_state")
}

// =============================================================================
// PRICING RULES (brand → category → product override hierarchy)
// =============================================================================

model PricingRule {
  id              String       @id @default(cuid())
  brandId         String       @map("brand_id")
  brand           Brand        @relation(fields: [brandId], references: [id])

  // Scope: null = brand default, set = category or product override
  categoryId      String?      @map("category_id")
  category        Category?    @relation(fields: [categoryId], references: [id])
  productId       String?      @map("product_id")
  syncProduct     SyncProduct? @relation(fields: [productId], references: [id])

  // Pricing config
  markupPercent   Float        @default(15.0) @map("markup_percent")
  fixedPriceCents BigInt?      @map("fixed_price_cents")
  manualMapCents  BigInt?      @map("manual_map_cents")

  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  // One rule per scope level
  @@unique([brandId, categoryId, productId])
  @@index([brandId])
  @@index([productId])
  @@map("pricing_rules")
}
